# Collab47 environment variables
# Copy to `.env.local` and fill in real values before deploy.

# Supabase project URL + anon key (browser-safe)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. SERVER-ONLY. Never expose to browser.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated handles allowed into /queue admin moderation dashboard.
# Example: ADMIN_HANDLES=akshpreet,shaurya
ADMIN_HANDLES=

# Secret for the hourly news cron endpoint. Vercel Cron sends this.
CRON_SECRET=

# Optional NewsAPI key (free tier). Leave blank to skip that source.
NEWS_API_KEY=

# When all of the above are blank, the app runs in mock-data mode
# so design QA still works without a backend.
